def compute_splade_vector(text: str) -> dict:
    """
    Tokenizes text, evaluates token routing log-weight via SPLADE layers,
    and returns a clean dictionary containing the active sparse indices and values.
    """
    inputs = tokenizer(text, return_tensors="pt", padding=True, truncation=True, max_length=512)
    
    with torch.no_grad():
        output = model(**inputs)
        
    logits = output.logits
    relu_log = torch.log(1 + torch.relu(logits))
    sparse_vec, _ = torch.max(relu_log, dim=1)
    sparse_vec = sparse_vec.squeeze()
    
    # Isolate tokens that received operational weights
    non_zero_indices = sparse_vec.nonzero().squeeze()
    if non_zero_indices.dim() == 0: 
        non_zero_indices = non_zero_indices.unsqueeze(0)
        
    return {
        "indices": non_zero_indices.tolist(),
        "values": sparse_vec[non_zero_indices].tolist()
    }

def index_document(doc_id: int, text: str, intents: list, tags: list):
    """
    Computes the sparse vector for a document and pushes it into the 
    database collection along with the structured array metadata payload.
    """
    # Run sparse embedding generation
    sparse_data = compute_splade_vector(text)
    
    # Construct the metadata payload dictionary
    payload = {
        "original_text": text,
        "intents": intents,
        "tags": tags
    }
    
    # Upsert the structural point directly into Qdrant
    client.upsert(
        collection_name=COLLECTION_NAME,
        points=[
            models.PointStruct(
                id=doc_id,
                vector={
                    "splade_vector": models.SparseVector(
                        indices=sparse_data["indices"],
                        values=sparse_data["values"]
                    )
                },
                payload=payload
            )
        ]
    )

def search_with_intent_filter(query: str, target_intent: str = None, top_k: int = 3) -> list:
    """
    Runs a query vector against the index, applying a strict pre-filter 
    condition against the intents array metadata when provided.
    """
    # Embed the search query
    query_data = compute_splade_vector(query)
    
    # Construct the array-matching condition if a filter is set
    search_filter = None
    if target_intent:
        search_filter = models.Filter(
            must=[
                models.FieldCondition(
                    key="intents",
                    match=models.MatchValue(value=target_intent)
                )
            ]
        )
        
    # Execute retrieval
    results = client.search(
        collection_name=COLLECTION_NAME,
        query_vector=models.NamedSparseVector(
            name="splade_vector",
            vector=models.SparseVector(
                indices=query_data["indices"],
                values=query_data["values"]
            )
        ),
        query_filter=search_filter,
        limit=top_k
    )
    
    # Format and return hits
    return [
        {
            "score": hit.score,
            "text": hit.payload["original_text"],
            "intents": hit.payload["intents"],
            "tags": hit.payload["tags"]
        } for hit in results
    ]

