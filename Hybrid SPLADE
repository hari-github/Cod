from typing import List
from pydantic import BaseModel, Field
from langchain_core.prompts import ChatPromptTemplate
from langchain_google_vertexai import ChatVertexAI

# 1. Define the structural output schema required by the downstream parser
class StructuredFeedbackSchema(BaseModel):
    intents: List[str] = Field(
        description="Array of applicable canonical intents. Must choose from: 'Billing Dispute', 'Coverage Inquiry', 'Customer Service Issue', 'Technical Error'."
    )
    tags: List[str] = Field(
        description="Array of 2 to 3 word highly descriptive phrases capturing explicit concepts, entities, or complaints (e.g., 'mri denial', 'long hold time'). Max 4 tags."
    )

# 2. Standalone function to handle the frontier model interaction
def extract_metadata(system_prompt: str, user_comment: str) -> StructuredFeedbackSchema:
    """
    Invokes the Gemini model to parse a text comment into the structured 
    array format specified by the StructuredFeedbackSchema.
    """
    # Initialize the Vertex AI Gemini model
    llm = ChatVertexAI(model_name="gemini-1.5-pro", temperature=0.0)
    structured_llm = llm.with_structured_output(StructuredFeedbackSchema)
    
    # Structure the prompt messages
    prompt_template = ChatPromptTemplate.from_messages([
        ("system", system_prompt),
        ("human", "{comment}")
    ])
    
    # Chain components and execute
    extraction_chain = prompt_template | structured_llm
    return extraction_chain.invoke({"comment": user_comment})


import torch
from transformers import AutoModelForMaskedLM, AutoTokenizer
from qdrant_client import QdrantClient
from qdrant_client import models

# Define configuration parameters
COLLECTION_NAME = "structured_health_feedback"

# 1. Initialize the Qdrant Client in-memory for testing
print("Initializing Qdrant storage engine...")
client = QdrantClient(":memory:")

# 2. Download and initialize the local transformer layers for sparse encoding
print("Loading local SPLADE model layers (this may take a moment)...")
tokenizer = AutoTokenizer.from_pretrained("naver/splade-v3-distilbert")
model = AutoModelForMaskedLM.from_pretrained("naver/splade-v3-distilbert")
model.eval() # Set model to evaluation mode for inference

# 3. Provision the sparse database collection
if not client.collection_exists(COLLECTION_NAME):
    client.create_collection(
        collection_name=COLLECTION_NAME,
        vectors_config={}, # Pass empty dict to explicitly bypass dense indexing
        sparse_vectors_config={
            "splade_vector": models.SparseVectorParams() # Configure the explicit sparse layer
        }
    )
    print(f"Collection '{COLLECTION_NAME}' successfully created.")
else:
    print(f"Collection '{COLLECTION_NAME}' already exists.")



