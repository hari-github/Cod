# 1. System Prompt Definition
SYSTEM_PROMPT = """You are an expert healthcare operations analyst. 
Extract applicable overarching intents and specific descriptive 2-3 word phrase tags from the user feedback. 
Ensure intents map strictly to canonical categories. Be precise with tags, keeping them short."""

# 2. Raw unstructured input feedback dataset
raw_feedbacks = [
    "I was on hold for two full hours, and when the agent finally picked up, they told me my prior authorization for the knee MRI was rejected.",
    "The portal gave me a network error when I tried uploading my claim documentation. Now I am missing the filing deadline!",
    "The medical treatment was fine, but the billing department sent me a huge invoice because they typed the coding wrong."
]

print("--- Step 1: Processing Extracted Metadata & Indexing ---")
for index, comment in enumerate(raw_feedbacks, start=1):
    # Call the extraction function directly
    extracted_metadata = extract_metadata(system_prompt=SYSTEM_PROMPT, user_comment=comment)
    
    print(f"\nDocument ID {index} Processing:")
    print(f" -> Generated Intents: {extracted_metadata.intents}")
    print(f" -> Generated Tags   : {extracted_metadata.tags}")
    
    # Push into the database using top-level functions and arrays
    index_document(
        doc_id=index, 
        text=comment, 
        intents=extracted_metadata.intents, 
        tags=extracted_metadata.tags
    )

print("\n--- Step 2: Running Metadata-Routed Sparse Query ---")

# Define target search string and metadata pre-filter
query_string = "prior auth rejection or service delays"
target_filter = "Coverage Inquiry"

# Execute the search function
search_results = search_with_intent_filter(
    query=query_string, 
    target_intent=target_filter, 
    top_k=2
)

# Render output results
print(f"\nSearch matches for query '{query_string}' isolated by intent '{target_filter}':")
for rank, match in enumerate(search_results, start=1):
    print(f"\n[Rank {rank}] Similarity Score: {match['score']:.4f}")
    print(f"Text: {match['text']}")
    print(f"Associated Intents: {match['intents']}")
    print(f"Associated Tags   : {match['tags']}")
